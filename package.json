{
  "name": "product-shot-studio",
  "version": "0.3.4",
  "private": true,
  "description": "Windows desktop MVP for generating commercial product showcase images with mainstream image models.",
  "author": "Product Shot Studio",
  "main": "dist/main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:all": "concurrently \"npm:server:dev\" \"npm:dev\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on http://127.0.0.1:5173 dist/main/main.js && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .",
    "server:dev": "npm --prefix server run dev",
    "server:build": "npm --prefix server run build",
    "server:test": "npm --prefix server test",
    "server:db:init": "npm --prefix server run db:init",
    "start": "electron .",
    "build": "npm run server:build && npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build:icon": "electron scripts/generate-app-icon.cjs",
    "prepackage:win": "npm run build:icon",
    "package:win": "npm run build && electron-builder --win --x64 && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-win-zip.ps1",
    "ensure:electron": "node scripts/ensure-electron.cjs",
    "live:smoke": "npm run build && node scripts/live-smoke.cjs",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "lint": "npm run typecheck"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "gsap": "^3.15.0",
    "sql.js": "^1.12.0"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^32.3.3",
    "electron-builder": "^26.8.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.19",
    "vitest": "^2.1.9",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.productshotstudio.app",
    "productName": "Product Shot Studio",
    "electronVersion": "32.3.3",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "outputs/package"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "node_modules/sql.js/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      },
      {
        "from": "server/dist",
        "to": "backend/dist"
      },
      {
        "from": "server/node_modules",
        "to": "backend/node_modules"
      },
      {
        "from": "server/package.json",
        "to": "backend/package.json"
      },
      {
        "from": "server/prisma",
        "to": "backend/prisma"
      },
      {
        "from": "build/app-icon.png",
        "to": "app-icon.png"
      }
    ],
    "win": {
      "icon": "build/app-icon.png",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Product Shot Studio",
      "runAfterFinish": true
    },
    "npmRebuild": false,
    "asar": true
  }
}
